    "NSFaceIDUsageDescription" : {
      "comment" : "Эта фраза должна объяснять, зачем нужна биометрия.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Required for secure access to your lectures and to protect your personal data."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Requis pour un accès sécurisé à vos cours et pour protéger vos données personnelles."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Requis pour un accès sécurisé à vos cours et pour protéger vos données personnelles."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Необходимо для безопасного доступа к вашим лекциям и защиты личных данных."
          }
        }
      }
    },
    "NSLocalNetworkUsageDescription" : {
      "comment" : "Здесь важно уточнить, что это нужно для работы ИИ.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Local network access is required to connect to the speech recognition server."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'accès au réseau local est nécessaire pour se connecter au serveur de reconnaissance vocale."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accesul la rețeaua locală este necesar pentru conectarea la serverul de recunoaștere vocală."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нам нужен доступ к локальной сети для связи с сервером распознавания речи."
          }
        }
      }
    },
    "NSMicrophoneUsageDescription" : {
      "comment" : "Краткое описание того, что будет записываться.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow microphone access to record and transcribe your lectures."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorisez l'accès au micro de manière à enregistrer et transcrire vos cours."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permiteți accesul la microfon pentru înregistrarea și transcrierea prelegerilor."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешите доступ к микрофону для записи и последующей расшифровки лекций."
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription" : {
      "comment" : "Пояснение, что аудио будет превращаться в текст.",
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Used to convert your audio recordings into structured text notes."
